# Antigravity / KAIROS — environment variables
# Copy this file to .env and fill in your keys
# NEVER commit the real .env file

# OpenRouter (Qwen, DeepSeek, Mistral, Hermes, Llama, Arcee, GLM)
OPENROUTER_API_KEY=

# Groq (fast inference — Llama, Mixtral)
GROQ_API_KEY=

# Google Gemini (vision extraction, large context)
GEMINI_API_KEY=

# Mistral AI (fallback coding + chat)
MISTRAL_API_KEY=

# Hugging Face (experimental models)
HF_TOKEN=

# GitHub (git permission layer)
GITHUB_TOKEN=

# Cerebras (large context tasks >20k tokens)
CEREBRAS_API_KEY=

# DeepSeek (direct API, alternative to OpenRouter)
DEEPSEEK_API_KEY=
