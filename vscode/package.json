{
  "name": "kairos",
  "displayName": "kairos AI",
  "description": "Multi-Agent · LiteLLM-Routed · Cost-Optimised AI Engineering Assistant",
  "version": "0.1.0",
  "publisher": "kairos-dev",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Programming Languages", "Other"],
  "keywords": ["ai", "llm", "copilot", "agent", "litellm"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "In untrusted workspaces, file write and terminal execution are disabled. Read-only mode is available.",
      "restrictedConfigurations": [
        "kairos.enableTerminal",
        "kairos.enableFileWrite",
        "kairos.enableFullAccess"
      ]
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "kairos.openChat",
        "title": "Open Chat",
        "category": "KAIROS",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "kairos.fix",
        "title": "Fix Issue",
        "category": "KAIROS",
        "icon": "$(wrench)"
      },
      {
        "command": "kairos.explain",
        "title": "Explain Selection",
        "category": "KAIROS",
        "icon": "$(lightbulb)"
      },
      {
        "command": "kairos.optimize",
        "title": "Optimize",
        "category": "KAIROS",
        "icon": "$(rocket)"
      },
      {
        "command": "kairos.generateTests",
        "title": "Generate Tests",
        "category": "KAIROS",
        "icon": "$(beaker)"
      },
      {
        "command": "kairos.refactor",
        "title": "Refactor",
        "category": "KAIROS",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "kairos.configure",
        "title": "Configure",
        "category": "KAIROS",
        "icon": "$(settings-gear)"
      },
      {
        "command": "kairos.clearChat",
        "title": "Clear Chat",
        "category": "KAIROS",
        "icon": "$(clear-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kairos-sidebar",
          "title": "KAIROS AI",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "kairos-sidebar": [
        {
          "type": "webview",
          "id": "kairos.chatView",
          "name": "Chat",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "kairos.fix",
          "group": "kairos@1",
          "when": "editorTextFocus"
        },
        {
          "command": "kairos.explain",
          "group": "kairos@2",
          "when": "editorHasSelection"
        },
        {
          "command": "kairos.optimize",
          "group": "kairos@3",
          "when": "editorHasSelection"
        },
        {
          "command": "kairos.generateTests",
          "group": "kairos@4",
          "when": "editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "kairos.clearChat",
          "when": "view == kairos.chatView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "kairos AI",
      "properties": {
        "kairos.litellmBaseUrl": {
          "type": "string",
          "default": "https://kairos-litellm.onrender.com",
          "description": "LiteLLM proxy base URL",
          "order": 1
        },
        "kairos.litellmApiKey": {
          "type": "string",
          "default": "sk-KAIROS",
          "description": "LiteLLM proxy API key (set in LiteLLM config)",
          "order": 2
        },
        "kairos.defaultModel": {
          "type": "string",
          "default": "gpt-oss-120b",
          "enum": [
            "qwen3-coder",
            "llama-3.3-70b",
            "hermes-3-405b",
            "gpt-oss-120b",
            "gpt-oss-20b",
            "gemma-3-27b",
            "gemma-4-31b",
            "qwen3-next-80b",
            "nemotron-3-super",
            "step-3.5-flash",
            "nemotron-nano-9b",
            "arcee-trinity-mini",
            "dolphin-mistral-24b",
            "lfm-2.5-1.2b-thinking",
            "nemotron-nano-12b-vl",
            "gemma-4-26b-vision",
            "groq-llama-3.3-70b",
            "groq-qwen-qwq-32b",
            "codestral",
            "gemini-2.5-pro",
            "github-deepseek-r1",
            "deepseek-local-fast",
            "deepseek-local-quality"
          ],
          "enumDescriptions": [
            "[OpenRouter] Qwen 3 Coder 480B (Best for Coding)",
            "[OpenRouter] Llama 3.3 70B (State-of-the-art Meta)",
            "[OpenRouter] Hermes 3 405B (Largest Open Source)",
            "[OpenRouter] GPT-OSS 120B (Best Flagship)",
            "[OpenRouter] GPT-OSS 20B (Balanced)",
            "[OpenRouter] Gemma 3 27B (Google Flagship)",
            "[OpenRouter] Gemma 4 31B (Google Flagship)",
            "[OpenRouter] Qwen 3 Next 80B (Balanced)",
            "[OpenRouter] Nemotron 3 Super 120B (Coding)",
            "[OpenRouter] Step 3.5 Flash (Fast AutoComplete)",
            "[OpenRouter] Nemotron Nano 9B (Fast AutoComplete)",
            "[OpenRouter] Arcee Trinity Mini (Fast)",
            "[OpenRouter] Dolphin Mistral 24B (Creative)",
            "[OpenRouter] LFM 2.5 1.2B Thinking (Deep Reason)",
            "[OpenRouter] Nemotron Nano 12B VL (Vision)",
            "[OpenRouter] Gemma 4 26B Vision (Vision)",
            "[Groq] Llama 3.3 70B (Ultra-fast)",
            "[Groq] Qwen QwQ 32B (Ultra-fast Logic)",
            "[Mistral] Codestral (Coding)",
            "[Gemini] Gemini 2.5 Pro (Large Context)",
            "[GitHub] DeepSeek R1 (Deep Reason)",
            "[Local] KAIROS R1 8B (Fast / 6GB VRAM)",
            "[Local] KAIROS R1 14B (Quality / 16GB+ RAM)"
          ],
          "description": "Default model for general tasks",
          "order": 3
        },

        "kairos.maxContextLines": {
          "type": "number",
          "default": 200,
          "minimum": 50,
          "maximum": 1000,
          "description": "Max lines of active file to include as context",
          "order": 4
        },
        "kairos.includeOpenFiles": {
          "type": "boolean",
          "default": false,
          "description": "Include names of all open files as context",
          "order": 5
        },
        "kairos.autoSelectFamilyTimeout": {
          "type": "number",
          "default": 120000,
          "description": "Timeout (ms) for model family auto-selection",
          "order": 6
        },
        "kairos.enableTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Allow Kairos agent to run terminal commands via <execute> tags.",
          "order": 7
        },
        "kairos.enableFileWrite": {
          "type": "boolean",
          "default": true,
          "description": "Allow Kairos agent to write files via <write> tags.",
          "order": 8
        },
        "kairos.enableFullAccess": {
          "type": "boolean",
          "default": false,
          "description": "Enable full access mode — agent can read, write, and execute without per-action approval.",
          "order": 9
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:prod": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "vscode:prepublish": "npm run build:prod"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "esbuild": "^0.20.2"
  }
}
