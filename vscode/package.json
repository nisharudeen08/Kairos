{
  "name": "kairos",
  "displayName": "kairos AI",
  "description": "Multi-Agent · LiteLLM-Routed · Cost-Optimised AI Engineering Assistant",
  "version": "0.1.0",
  "publisher": "kairos-dev",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Programming Languages", "Other"],
  "keywords": ["ai", "llm", "copilot", "agent", "litellm"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kairos.openChat",
        "title": "Open Chat",
        "category": "KAIROS",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "kairos.fix",
        "title": "Fix Issue",
        "category": "KAIROS",
        "icon": "$(wrench)"
      },
      {
        "command": "kairos.explain",
        "title": "Explain Selection",
        "category": "KAIROS",
        "icon": "$(lightbulb)"
      },
      {
        "command": "kairos.optimize",
        "title": "Optimize",
        "category": "KAIROS",
        "icon": "$(rocket)"
      },
      {
        "command": "kairos.generateTests",
        "title": "Generate Tests",
        "category": "KAIROS",
        "icon": "$(beaker)"
      },
      {
        "command": "kairos.refactor",
        "title": "Refactor",
        "category": "KAIROS",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "kairos.configure",
        "title": "Configure",
        "category": "KAIROS",
        "icon": "$(settings-gear)"
      },
      {
        "command": "kairos.clearChat",
        "title": "Clear Chat",
        "category": "KAIROS",
        "icon": "$(clear-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kairos-sidebar",
          "title": "KAIROS AI",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "kairos-sidebar": [
        {
          "type": "webview",
          "id": "kairos.chatView",
          "name": "Chat",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "kairos.fix",
          "group": "kairos@1",
          "when": "editorTextFocus"
        },
        {
          "command": "kairos.explain",
          "group": "kairos@2",
          "when": "editorHasSelection"
        },
        {
          "command": "kairos.optimize",
          "group": "kairos@3",
          "when": "editorHasSelection"
        },
        {
          "command": "kairos.generateTests",
          "group": "kairos@4",
          "when": "editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "kairos.clearChat",
          "when": "view == kairos.chatView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "kairos AI",
      "properties": {
        "kairos.litellmBaseUrl": {
          "type": "string",
          "default": "http://localhost:4000",
          "description": "LiteLLM proxy base URL",
          "order": 1
        },
        "kairos.litellmApiKey": {
          "type": "string",
          "default": "sk-KAIROS",
          "description": "LiteLLM proxy API key (set in LiteLLM config)",
          "order": 2
        },
        "kairos.defaultModel": {
          "type": "string",
          "default": "gpt-oss-120b",
          "enum": [
            "gpt-oss-120b",
            "qwen3-coder",
            "llama-3.3-70b",
            "hermes-405b",
            "gemma-3-27b",
            "gpt-oss-20b",
            "qwen3-next-80b",
            "qwen3-6-plus",
            "nemotron-30b",
            "gemma-3-12b",
            "stepfun-flash",
            "glm-4-5-air",
            "dolphin-mistral-24b",
            "gemma-3-4b",
            "gemma-3n-e4b",
            "nemotron-nano-9b",
            "nemotron-embed-vl",
            "lfm-thinking",
            "lfm-instruct",
            "llama-3.2-3b"
          ],
          "enumDescriptions": [
            "GPT OSS 120B (Best Flagship)",
            "Qwen 3 Coder (Best for Coding)",
            "Llama 3.3 70B (State-of-the-art Meta)",
            "Hermes 3 405B (Largest Open Source)",
            "Gemma 3 27B (Google Flagship)",
            "GPT OSS 20B (Balanced)",
            "Qwen 3 Next 80B (Balanced)",
            "Qwen 3.6 Plus (Balanced)",
            "Nemotron 30B (NVIDIA)",
            "Gemma 3 12B (Balanced)",
            "StepFun 3.5 Flash (Fast)",
            "GLM 4.5 Air (Fast)",
            "Dolphin Mistral 24B (Creative)",
            "Gemma 3 4B (Ultra-fast)",
            "Gemma 3n E4B (Efficient)",
            "Nemotron Nano 9B (Specialty)",
            "Nemotron Embed VL (Vision)",
            "LFM 2.5 Thinking (Deep Reason)",
            "LFM 2.5 Instruct (Specialty)",
            "Llama 3.2 3B (Edge)"
          ],
          "description": "Default model for general tasks",
          "order": 3
        },

        "kairos.maxContextLines": {
          "type": "number",
          "default": 200,
          "minimum": 50,
          "maximum": 1000,
          "description": "Max lines of active file to include as context",
          "order": 4
        },
        "kairos.includeOpenFiles": {
          "type": "boolean",
          "default": false,
          "description": "Include names of all open files as context",
          "order": 5
        },
        "kairos.autoSelectFamilyTimeout": {
          "type": "number",
          "default": 30000,
          "description": "Timeout (ms) for each model attempt during auto-selection/fallback",
          "order": 6
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:prod": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "vscode:prepublish": "npm run build:prod"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "esbuild": "^0.20.2"
  }
}
