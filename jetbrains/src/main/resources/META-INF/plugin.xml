<idea-plugin>
    <id>com.antigravity.plugin</id>
    <name>Antigravity AI</name>
    <version>0.1.0</version>
    <vendor>Antigravity Dev</vendor>

    <description><![CDATA[
      Multi-Agent · LiteLLM-Routed · Cost-Optimised AI Engineering Assistant<br>
      <em>Free models first. Streaming responses. Multi-IDE context.</em>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Sidebar Tool Window -->
        <toolWindow id="AntigravityChat" 
                    anchor="right" 
                    secondary="false" 
                    icon="/media/sidebar-icon.svg" 
                    factoryClass="com.antigravity.ui.AntigravityToolWindowFactory"/>
        
        <!-- Settings Panel -->
        <applicationConfigurable id="com.antigravity.settings"
                                 displayName="Antigravity AI"
                                 instance="com.antigravity.settings.AntigravityConfigurable"/>
    </extensions>

    <actions>
        <!-- Editor Context Menu -->
        <group id="Antigravity.ContextMenu" text="Antigravity AI" popup="true" icon="AllIcons.Actions.Lightning">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <action id="Antigravity.Fix" class="com.antigravity.actions.FixAction" text="Fix" description="Fix the selected code"/>
            <action id="Antigravity.Explain" class="com.antigravity.actions.ExplainAction" text="Explain" description="Explain the selected code"/>
            <action id="Antigravity.Optimize" class="com.antigravity.actions.OptimizeAction" text="Optimize" description="Optimize the selected code"/>
        </group>
    </actions>
</idea-plugin>
