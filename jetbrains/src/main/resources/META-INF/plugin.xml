<idea-plugin>
  <id>ai.kairos.jetbrains</id>
  <name>Kairos AI</name>
  <vendor>KairosAI</vendor>
  <description>Kairos AI chat powered by LiteLLM proxy</description>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">

    <!-- Tool Window (sidebar panel) -->
    <toolWindow
      id="Kairos"
      displayName="Kairos AI"
      anchor="right"
      factoryClass="com.antigravity.ui.KairosToolWindowFactory"
      icon="/icons/kairos.svg"/>

    <!-- Settings page -->
    <applicationConfigurable
      parentId="tools"
      instance="ai.kairos.settings.KairosSettingsConfigurable"
      id="ai.kairos.settings"
      displayName="Kairos AI"/>

    <!-- Persistent settings storage -->
    <applicationService
      serviceImplementation="ai.kairos.settings.KairosSettings"/>

  </extensions>

  <actions>
    <!-- Alt+K shortcut to open chat -->
    <action
      id="Kairos.OpenChat"
      class="ai.kairos.actions.OpenKairosChatAction"
      text="Open Kairos Chat"
      description="Open Kairos AI chat panel">
      <keyboard-shortcut keymap="$default" first-keystroke="alt K"/>
    </action>
  </actions>

</idea-plugin>
