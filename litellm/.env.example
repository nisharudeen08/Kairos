# Antigravity AI — LiteLLM API Keys
# Copy this file to .env and fill in the keys you have.
# You only need at least ONE of the free providers to get started.
#
# FREE providers (start here):
#   - OpenRouter: https://openrouter.ai/keys  (covers Qwen, DeepSeek, Mistral)
#   - Groq:       https://console.groq.com/keys
#   - Gemini:     https://aistudio.google.com/app/apikey
#
# PAID providers (optional):
#   - Cerebras:   https://inference.cerebras.ai/
#   - Anthropic:  https://console.anthropic.com/ (Claude — locked by default)

# ── Free providers (at least one required) ────────────────────────────────────
# You can add multiple keys for rotation (OPENROUTER_API_KEY_1, _2, _3 etc.)
OPENROUTER_API_KEY_1=sk-or-v1-...
OPENROUTER_API_KEY_2=sk-or-v1-...
OPENROUTER_API_KEY_3=sk-or-v1-...

OLLAMA_BASE_URL=http://WINDOWS_LOCAL_IP:11434
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AI...

# ── Optional / paid providers ─────────────────────────────────────────────────
CEREBRAS_API_KEY=
ANTHROPIC_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# KAIROS AI - FREE PROVIDER KEYS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Provider 1: OpenRouter (already exists, skip if present)
OPENROUTER_API_KEY=your_openrouter_key_here

# Provider 3: Mistral — console.mistral.ai
MISTRAL_API_KEY=your_mistral_key_here

# Provider 5: GitHub Models — github.com/settings/tokens
# Create a classic token, no scopes needed
GITHUB_API_KEY=your_github_token_here
